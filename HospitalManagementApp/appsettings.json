{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=HospitalManagementApp.local.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "FileLogging": {
    "Enabled": true,
    "DirectoryPath": "Logs",
    "FileNamePrefix": "hospital-app",
    "MinimumLevel": "Information"
  },
  "IdentitySeed": {
    "AdminEmail": "admin@hospital.local",
    "AdminPassword": "Admin12345",
    "AdminFirstName": "System",
    "AdminLastName": "Admin"
  },
  "Authentication": {
    "Google": {
      "ClientId": "",
      "ClientSecret": ""
    },
    "Facebook": {
      "AppId": "",
      "AppSecret": ""
    }
  },
  "FileUpload": {
    "MaxSizeMb": 20,
    "PatientFilesRootFolder": "uploads/pacijenti",
    "AllowedContentTypes": [
      "application/pdf",
      "image/jpeg",
      "image/png",
      "application/dicom",
      "application/octet-stream"
    ]
  },
  "AllowedHosts": "*"
}
