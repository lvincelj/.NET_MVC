@model IEnumerable<HospitalManagementApp.Models.Doctor>
@{
    var canManage = User.IsInRole("Admin") || User.IsInRole("Doctor");
    var canDelete = User.IsInRole("Admin");
}

@if (!Model.Any())
{
    <div class="alert alert-info hm-empty-state">No doctors found.</div>
}
else
{
    <div class="hm-cards-grid hm-cards-grid--index">
        @foreach (var item in Model)
        {
            <article class="hm-card hm-record-card">
                <div class="hm-card__header">
                    <span class="hm-card__title">Dr. @item.FirstName @item.LastName</span>
                    <span class="hm-card__badge hm-card__badge--active">@item.Specialty</span>
                </div>
                <div class="hm-card__body">
                    <p><strong>Gender:</strong> @item.Gender</p>
                    <p><strong>Email:</strong> @(string.IsNullOrWhiteSpace(item.Email) ? "-" : item.Email)</p>
                    <p><strong>Phone:</strong> @(string.IsNullOrWhiteSpace(item.PhoneNumber) ? "-" : item.PhoneNumber)</p>
                </div>
                <div class="hm-card__footer hm-action-strip">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">View</a>
                    @if (canManage)
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    }
                    @if (canDelete)
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    }
                </div>
            </article>
        }
    </div>
}
