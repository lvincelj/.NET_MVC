@model IEnumerable<HospitalManagementApp.Models.Doctor>
@{
    var doctors = Model.OrderBy(d => d.LastName).ThenBy(d => d.FirstName).ToList();
    ViewData["Title"] = "Doctors";
}

<div class="hm-page-header">
    <h1 class="hm-page-title">Doctors</h1>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb hm-breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Doctors</li>
        </ol>
    </nav>
</div>

<section class="hm-summary-strip">
    <article class="hm-summary-card hm-summary-card--accent">
        <span class="hm-summary-label">Total Doctors</span>
        <strong class="hm-summary-value">@doctors.Count</strong>
        <span class="hm-summary-meta">available on the roster</span>
    </article>
    <article class="hm-summary-card hm-summary-card--sky">
        <span class="hm-summary-label">Departments Covered</span>
        <strong class="hm-summary-value">@doctors.Sum(d => d.Departments.Count)</strong>
        <span class="hm-summary-meta">doctor-to-department assignments</span>
    </article>
    <article class="hm-summary-card hm-summary-card--violet">
        <span class="hm-summary-label">Appointments</span>
        <strong class="hm-summary-value">@doctors.Sum(d => d.Appointments.Count)</strong>
        <span class="hm-summary-meta">scheduled doctor visits</span>
    </article>
</section>

<section class="hm-list-section">
    <div class="hm-cards-grid hm-cards-grid--index">
        @foreach (var doctor in doctors)
        {
            <article class="hm-card hm-record-card">
                <div class="hm-card__header">
                    <span class="hm-card__title">Dr. @doctor.LastName</span>
                    <span class="hm-card__badge hm-card__badge--active">@doctor.Specialty</span>
                </div>
                <div class="hm-card__body">
                    <p class="hm-record-card__title">Dr. @doctor.FirstName @doctor.LastName</p>
                    <p class="hm-record-card__subtitle">@doctor.Departments.Count department assignments</p>
                    <div class="hm-record-card__meta">
                        <span>@doctor.Email</span>
                        <span>@doctor.PhoneNumber</span>
                        <span>@doctor.Appointments.Count appointments</span>
                    </div>
                </div>
                <div class="hm-card__footer">
                    <a class="hm-btn-primary" asp-controller="Doctors" asp-action="Details" asp-route-id="@doctor.Id">Details</a>
                </div>
            </article>
        }
    </div>
</section>
