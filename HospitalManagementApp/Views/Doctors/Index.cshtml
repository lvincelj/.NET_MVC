@model IEnumerable<HospitalManagementApp.Models.Doctor>
@{
    ViewData["Title"] = "Doctors";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Doctors</h1>
    <a asp-action="Create" class="btn btn-primary">Create Doctor</a>
</div>

<div class="mb-3">
    <input
        type="search"
        class="form-control"
        placeholder="Search by doctor name, specialty, email, or phone..."
        data-ajax-search="true"
        data-search-url="@Url.Action("Search", "Doctors")"
        data-search-target="#doctor-list" />
</div>

<div id="doctor-list">
    @await Html.PartialAsync("_DoctorList", Model)
</div>
