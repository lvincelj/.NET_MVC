@model HospitalManagementApp.Models.HomeDashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    var now = DateTime.Now;
    var scheduleHealth = Math.Min(100, Math.Max(12, Model.TodayAppointments * 7));
    var staffCapacity = Math.Min(100, Math.Max(18, Model.ActiveDoctors * 10));
    var documentationHealth = Math.Max(8, 100 - Math.Min(92, Model.PendingRecords * 6));
}

<div class="hm-dashboard">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb hm-breadcrumb">
            <li class="breadcrumb-item active" aria-current="page">Dashboard</li>
        </ol>
    </nav>

    <section class="hm-dashboard-hero hm-dashboard-hero--pro">
        <div class="hm-dashboard-hero__content">
            <span class="hm-dashboard-eyebrow">Live overview · @now.ToString("dd MMM yyyy")</span>
            <h1 class="hm-dashboard-title">Clinical Operations Dashboard</h1>
            <p class="hm-dashboard-subtitle">A focused command center for scheduling, staffing, and patient-flow visibility across your hospital.</p>
            <div class="hm-dashboard-hero__actions">
                <a class="hm-btn-primary" asp-controller="Appointments" asp-action="Index">Review Schedule</a>
                <a class="hm-btn-secondary" asp-controller="Patients" asp-action="Index">Open Patients</a>
            </div>

            <div class="hm-insight-strip" aria-label="Primary insights">
                <div class="hm-insight-pill">
                    <span>Appointments</span>
                    <strong>@Model.TodayAppointments</strong>
                </div>
                <div class="hm-insight-pill">
                    <span>Doctors Active</span>
                    <strong>@Model.ActiveDoctors</strong>
                </div>
                <div class="hm-insight-pill">
                    <span>Records Pending</span>
                    <strong>@Model.PendingRecords</strong>
                </div>
            </div>
        </div>

        <aside class="hm-dashboard-hero__aside hm-system-health" aria-label="System health">
            <span class="hm-dashboard-panel-label">System health</span>
            <div class="hm-health-row">
                <div class="hm-health-row__head">
                    <strong>Schedule readiness</strong>
                    <span>@scheduleHealth%</span>
                </div>
                <div class="hm-health-bar"><span style="width: @scheduleHealth%"></span></div>
            </div>
            <div class="hm-health-row">
                <div class="hm-health-row__head">
                    <strong>Staff capacity</strong>
                    <span>@staffCapacity%</span>
                </div>
                <div class="hm-health-bar"><span style="width: @staffCapacity%"></span></div>
            </div>
            <div class="hm-health-row">
                <div class="hm-health-row__head">
                    <strong>Documentation flow</strong>
                    <span>@documentationHealth%</span>
                </div>
                <div class="hm-health-bar"><span style="width: @documentationHealth%"></span></div>
            </div>
        </aside>
    </section>

    <section class="hm-kpi-grid" aria-label="Dashboard statistics">
        <article class="hm-kpi-card">
            <span class="hm-kpi-label">Patients</span>
            <strong class="hm-kpi-value">@Model.TotalPatients</strong>
            <span class="hm-kpi-meta">registered patient profiles</span>
        </article>
        <article class="hm-kpi-card">
            <span class="hm-kpi-label">Appointments Today</span>
            <strong class="hm-kpi-value">@Model.TodayAppointments</strong>
            <span class="hm-kpi-meta">scheduled visits for the current day</span>
        </article>
        <article class="hm-kpi-card">
            <span class="hm-kpi-label">Departments</span>
            <strong class="hm-kpi-value">@Model.DepartmentCount</strong>
            <span class="hm-kpi-meta">service areas available to staff</span>
        </article>
        <article class="hm-kpi-card">
            <span class="hm-kpi-label">Medication Catalog</span>
            <strong class="hm-kpi-value">@Model.MedicationCount</strong>
            <span class="hm-kpi-meta">active medication entries tracked</span>
        </article>
    </section>

    <section>
        <div class="hm-section-heading">
            <h2 class="hm-section-title">Quick Actions</h2>
            <p class="hm-section-copy">Jump directly into the areas that keep daily hospital workflows moving.</p>
        </div>
        <div class="hm-action-grid">
            @foreach (var action in Model.Actions)
            {
                <article class="hm-action-card hm-action-card--@action.Accent">
                    <div class="hm-action-card__topline">
                        <span class="hm-status-pill hm-status-pill--@action.Accent">@action.Metric</span>
                    </div>
                    <h3 class="hm-action-card__title">@action.Title</h3>
                    <p class="hm-action-card__text">@action.Description</p>
                    <div class="hm-action-card__links">
                        <a asp-controller="@action.Controller" asp-action="Index">Open module</a>
                    </div>
                </article>
            }
        </div>
    </section>

    <section class="hm-ops-grid">
        <article class="hm-ops-card">
            <div class="hm-section-heading hm-section-heading--tight">
                <h2 class="hm-section-title">Upcoming Appointments</h2>
                <p class="hm-section-copy">The next scheduled patient visits across the hospital.</p>
            </div>
            <div class="hm-ops-list">
                @foreach (var item in Model.UpcomingAppointments)
                {
                    <div class="hm-ops-item">
                        <div class="hm-ops-item__time">@item.TimeLabel</div>
                        <div class="hm-ops-item__body">
                            <strong>@item.PatientName</strong>
                            <span>@item.DoctorName · Room @item.Room</span>
                        </div>
                        <span class="hm-status-pill hm-status-pill--neutral">@item.Status</span>
                    </div>
                }
            </div>
        </article>

        <article class="hm-ops-card">
            <div class="hm-section-heading hm-section-heading--tight">
                <h2 class="hm-section-title">Operational Notes</h2>
                <p class="hm-section-copy">A quick pulse check on documentation and coverage.</p>
            </div>
            <div class="hm-note-list">
                @foreach (var note in Model.OperationalNotes)
                {
                    <div class="hm-note-item hm-note-item--@note.Tone">
                        <strong>@note.Title</strong>
                        <p>@note.Detail</p>
                    </div>
                }
            </div>
        </article>
    </section>
</div>
