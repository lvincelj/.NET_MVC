@model HospitalManagementApp.Models.Department
@{
    ViewData["Title"] = "Delete Department";
    var canDelete = ViewBag.CanDelete is bool b && b;
}

<h1>Delete Department</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Name</dd>
    <dt class="col-sm-3">Location</dt>
    <dd class="col-sm-9">@Model.Location</dd>
    <dt class="col-sm-3">Doctors Assigned</dt>
    <dd class="col-sm-9">@Model.Doctors.Count</dd>
</dl>

@if (!canDelete)
{
    <div class="alert alert-warning">This department cannot be deleted while doctors are assigned.</div>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Back</a>
}
else
{
    <p class="text-danger">Are you sure you want to delete this department?</p>
    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
    </form>
}
