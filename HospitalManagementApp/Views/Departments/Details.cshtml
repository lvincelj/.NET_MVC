@model HospitalManagementApp.Models.Department
@{
    ViewData["Title"] = Model.Name;
}

<div class="hm-page-header">
    <h1 class="hm-page-title">@Model.Name</h1>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb hm-breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Departments" asp-action="Index">Departments</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>
</div>

<a class="hm-back-link" asp-controller="Departments" asp-action="Index">‹ Back to Departments</a>

<div class="hm-detail-card">
    <div class="hm-detail-card__header">Department Details</div>
    <div class="hm-detail-card__body">
        <div class="hm-field-row">
            <span class="hm-field-label">Name</span>
            <span class="hm-field-value">@Model.Name</span>
        </div>
        <div class="hm-field-row">
            <span class="hm-field-label">Location</span>
            <span class="hm-field-value">@Model.Location</span>
        </div>
        <div class="hm-field-row">
            <span class="hm-field-label">Phone</span>
            <span class="hm-field-value">@Model.PhoneNumber</span>
        </div>
        <div class="hm-field-row">
            <span class="hm-field-label">Head of Department</span>
            <span class="hm-field-value">@Model.HeadOfDepartment</span>
        </div>
    </div>
</div>

@if (Model.Doctors != null && Model.Doctors.Any())
{
    <h2 class="hm-section-title">Doctors in this Department</h2>
    <section class="hm-cards-grid">
        @foreach (var doctor in Model.Doctors)
        {
            <div class="hm-card">
                <div class="hm-card__header">
                    <span class="hm-card__title">Dr. @doctor.FirstName @doctor.LastName</span>
                </div>
                <div class="hm-card__body">
                    <p><strong>Specialty:</strong> @doctor.Specialty</p>
                    <p><strong>Email:</strong> @doctor.Email</p>
                </div>
                <div class="hm-card__footer">
                    <a class="hm-btn-primary" asp-controller="Doctors" asp-action="Details" asp-route-id="@doctor.Id">Details</a>
                </div>
            </div>
        }
    </section>
}
