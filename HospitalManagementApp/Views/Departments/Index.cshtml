@model IEnumerable<HospitalManagementApp.Models.Department>
@{
    ViewData["Title"] = "Departments";
    var canManage = User.IsInRole("Admin") || User.IsInRole("Doctor");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Departments</h1>
    @if (canManage)
    {
        <a asp-action="Create" class="btn btn-primary">Create Department</a>
    }
</div>

<div class="mb-3">
    <input
        type="search"
        class="form-control"
        placeholder="Search by name, location, head, or phone..."
        data-ajax-search="true"
        data-search-url="@Url.Action("Search", "Departments")"
        data-search-target="#department-list" />
</div>

<div id="department-list">
    @await Html.PartialAsync("_DepartmentList", Model)
</div>
