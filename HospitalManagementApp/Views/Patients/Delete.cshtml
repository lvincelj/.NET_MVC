@model HospitalManagementApp.Models.Patient
@{
    ViewData["Title"] = "Delete Patient";
    var canDelete = ViewBag.CanDelete is bool b && b;
}

<h1>Delete Patient</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.FirstName @Model.LastName</dd>
    <dt class="col-sm-3">Date of Birth</dt>
    <dd class="col-sm-9">@Model.DateOfBirth.ToString("yyyy-MM-dd")</dd>
    <dt class="col-sm-3">Appointments</dt>
    <dd class="col-sm-9">@Model.Appointments.Count</dd>
    <dt class="col-sm-3">Medical Records</dt>
    <dd class="col-sm-9">@Model.MedicalRecords.Count</dd>
</dl>

@if (!canDelete)
{
    <div class="alert alert-warning">This patient cannot be deleted while appointments or medical records exist.</div>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Back</a>
}
else
{
    <p class="text-danger">Are you sure you want to delete this patient?</p>
    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
    </form>
}
