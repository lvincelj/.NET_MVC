@model IEnumerable<HospitalManagementApp.Models.Patient>
@{
    var canManage = User.IsInRole("Admin") || User.IsInRole("Doctor");
    var canDelete = User.IsInRole("Admin");
}

@if (!Model.Any())
{
    <div class="alert alert-info hm-empty-state">No patients found.</div>
}
else
{
    <div class="hm-cards-grid hm-cards-grid--index">
        @foreach (var item in Model)
        {
            <article class="hm-card hm-record-card">
                <div class="hm-card__header">
                    <span class="hm-card__title">@item.FirstName @item.LastName</span>
                    <span class="hm-card__badge hm-card__badge--@(item.Gender == HospitalManagementApp.Models.Gender.Female ? "female" : "male")">@item.Gender</span>
                </div>
                <div class="hm-card__body">
                    <p><strong>Birth Date:</strong> @item.DateOfBirth.ToString("yyyy-MM-dd")</p>
                    <p><strong>Email:</strong> @(string.IsNullOrWhiteSpace(item.Email) ? "-" : item.Email)</p>
                    <p><strong>Phone:</strong> @(string.IsNullOrWhiteSpace(item.PhoneNumber) ? "-" : item.PhoneNumber)</p>
                </div>
                <div class="hm-card__footer hm-action-strip">
                    <a href="/Patients/Details/@item.Id" class="btn btn-sm btn-outline-secondary hm-action-btn hm-action-btn--view" title="View" aria-label="View patient">View</a>
                    @if (canManage)
                    {
                        <a href="/Patients/Edit/@item.Id" class="btn btn-sm btn-outline-primary hm-action-btn hm-action-btn--edit" title="Edit" aria-label="Edit patient">Edit</a>
                    }
                    @if (canDelete)
                    {
                        <a href="/Patients/Delete/@item.Id" class="btn btn-sm btn-outline-danger hm-action-btn hm-action-btn--delete" title="Delete" aria-label="Delete patient">Delete</a>
                    }
                </div>
            </article>
        }
    </div>
}
