@model IEnumerable<HospitalManagementApp.Models.Patient>
@{
    ViewData["Title"] = "Patients";
    var canManage = User.IsInRole("Admin") || User.IsInRole("Doctor");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Patients</h1>
    @if (canManage)
    {
        <a asp-action="Create" class="btn btn-primary">Create Patient</a>
    }
</div>

<div class="mb-3">
    <input
        type="search"
        class="form-control"
        placeholder="Search by patient name, email, phone, or address..."
        data-ajax-search="true"
        data-search-url="@Url.Action("Search", "Patients")"
        data-search-target="#patient-list" />
</div>

<div id="patient-list">
    @await Html.PartialAsync("_PatientList", Model)
</div>
