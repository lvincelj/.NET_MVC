@model IEnumerable<HospitalManagementApp.Models.Patient>
@{
    var patients = Model.OrderBy(p => p.LastName).ThenBy(p => p.FirstName).ToList();
    ViewData["Title"] = "Patients";
}

<div class="hm-page-header">
    <h1 class="hm-page-title">Patients</h1>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb hm-breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Patients</li>
        </ol>
    </nav>
</div>

<section class="hm-summary-strip">
    <article class="hm-summary-card hm-summary-card--accent">
        <span class="hm-summary-label">Total Patients</span>
        <strong class="hm-summary-value">@patients.Count</strong>
        <span class="hm-summary-meta">registered patient profiles</span>
    </article>
    <article class="hm-summary-card hm-summary-card--sky">
        <span class="hm-summary-label">With Records</span>
        <strong class="hm-summary-value">@patients.Count(p => p.MedicalRecords.Any())</strong>
        <span class="hm-summary-meta">patients with medical history</span>
    </article>
    <article class="hm-summary-card hm-summary-card--violet">
        <span class="hm-summary-label">Appointments</span>
        <strong class="hm-summary-value">@patients.Sum(p => p.Appointments.Count)</strong>
        <span class="hm-summary-meta">linked appointments across patients</span>
    </article>
</section>

<section class="hm-list-section">
    <div class="hm-cards-grid hm-cards-grid--index">
        @foreach (var patient in patients)
        {
            <article class="hm-card hm-record-card">
                <div class="hm-card__header">
                    <span class="hm-card__title">Patient #@patient.Id</span>
                    <span class="hm-card__badge hm-card__badge--@patient.Gender.ToString().ToLower()">@patient.Gender</span>
                </div>
                <div class="hm-card__body">
                    <p class="hm-record-card__title">@patient.FirstName @patient.LastName</p>
                    <p class="hm-record-card__subtitle">Born @patient.DateOfBirth.ToString("dd MMM yyyy")</p>
                    <div class="hm-record-card__meta">
                        <span>@patient.Email</span>
                        <span>@patient.PhoneNumber</span>
                        <span>@patient.MedicalRecords.Count medical records</span>
                    </div>
                </div>
                <div class="hm-card__footer">
                    <a class="hm-btn-primary" asp-controller="Patients" asp-action="Details" asp-route-id="@patient.Id">Details</a>
                </div>
            </article>
        }
    </div>
</section>
