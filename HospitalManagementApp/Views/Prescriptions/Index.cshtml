@model IEnumerable<HospitalManagementApp.Models.Prescription>
@{
    ViewData["Title"] = "Prescriptions";
}

<div class="hm-page-header">
    <h1 class="hm-page-title">Prescriptions</h1>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb hm-breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Prescriptions</li>
        </ol>
    </nav>
</div>

<div class="hm-table-wrap">
    <table class="hm-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Patient</th>
                <th>Issued By</th>
                <th>Issued At</th>
                <th>Medications</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var prescription in Model)
            {
                <tr>
                    <td>@prescription.Id</td>
                    <td>@(prescription.MedicalRecord?.Patient != null ? $"{prescription.MedicalRecord.Patient.FirstName} {prescription.MedicalRecord.Patient.LastName}" : "—")</td>
                    <td>@prescription.IssuedBy</td>
                    <td>@prescription.IssuedAt.ToString("dd MMM yyyy")</td>
                    <td>@prescription.Medications.Count</td>
                    <td><a class="hm-btn-primary" asp-controller="Prescriptions" asp-action="Details" asp-route-id="@prescription.Id">Details</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>
