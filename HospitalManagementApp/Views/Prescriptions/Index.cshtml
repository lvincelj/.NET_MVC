@model IEnumerable<HospitalManagementApp.Models.Prescription>
@{
    ViewData["Title"] = "Prescriptions";
    var canManage = User.IsInRole("Admin") || User.IsInRole("Doctor");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Prescriptions</h1>
    @if (canManage)
    {
        <a asp-action="Create" class="btn btn-primary">Create Prescription</a>
    }
</div>

<div class="mb-3">
    <input
        type="search"
        class="form-control"
        placeholder="Search prescriptions..."
        data-ajax-search="true"
        data-search-url="@Url.Action("Search", "Prescriptions")"
        data-search-target="#prescription-list" />
</div>

<div id="prescription-list">
    @await Html.PartialAsync("_PrescriptionList", Model)
</div>
