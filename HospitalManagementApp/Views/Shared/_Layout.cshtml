@using HospitalManagementApp.Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<AppUser> SignInManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — CareFlow</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
<div class="hm-layout">

    <div class="hm-ambient" aria-hidden="true">
        <span class="hm-ambient__blob hm-ambient__blob--one"></span>
        <span class="hm-ambient__blob hm-ambient__blob--two"></span>
        <span class="hm-ambient__blob hm-ambient__blob--three"></span>
        <span class="hm-ambient__grid"></span>
    </div>

    <aside class="hm-sidebar" aria-label="Main navigation">
        <a class="hm-sidebar__brand" asp-controller="Home" asp-action="Index">
            <span class="hm-logo-mark" aria-hidden="true">
                <span></span>
            </span>
            <span class="hm-sidebar__brand-text">
                <strong>CareFlow</strong>
                <em>Hospital OS</em>
            </span>
        </a>
        <ul class="hm-sidebar__nav" role="list">
            <li><a asp-controller="Home" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                <span>Dashboard</span></a></li>
            <li><a asp-controller="Patients" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Patients" ? "active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <span>Patients</span></a></li>
            <li><a asp-controller="Doctors" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Doctors" ? "active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9a9 9 0 1 0 18 0A9 9 0 0 0 3 9z"/><path d="M12 6v3l2 2"/></svg>
                <span>Doctors</span></a></li>
            <li><a asp-controller="Departments" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Departments" ? "active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <span>Departments</span></a></li>
            <li><a asp-controller="Appointments" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Appointments" ? "active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <span>Appointments</span></a></li>
            <li><a asp-controller="MedicalRecords" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "MedicalRecords" ? "active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="11" x2="12" y2="17"/><line x1="9" y1="14" x2="15" y2="14"/></svg>
                <span>Medical Records</span></a></li>
            <li><a asp-controller="Medications" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Medications" ? "active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.5 20H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v7"/><circle cx="17" cy="17" r="5"/><path d="M17 14v6M14 17h6"/></svg>
                <span>Medications</span></a></li>
            <li><a asp-controller="Prescriptions" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Prescriptions" ? "active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="2"/><path d="M9 12h6M9 16h4"/></svg>
                <span>Prescriptions</span></a></li>
        </ul>

        <div class="px-3 pb-3 mt-auto hm-sidebar-auth">
            @if (SignInManager.IsSignedIn(User))
            {
                <div class="small text-white-50 mb-2">Signed in as @User.Identity?.Name</div>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm w-100 hm-auth-btn hm-auth-btn--ghost hm-auth-btn--logout">
                        <span class="hm-auth-btn__text">Logout</span>
                    </button>
                </form>
            }
            else
            {
                <div class="d-grid gap-2">
                    <a asp-controller="Account" asp-action="Login" class="btn btn-sm hm-auth-btn hm-auth-btn--ghost hm-auth-btn--login">
                        <span class="hm-auth-btn__text">Login</span>
                    </a>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-sm hm-auth-btn hm-auth-btn--solid hm-auth-btn--register">
                        <span class="hm-auth-btn__text">Register</span>
                    </a>
                </div>
            }
        </div>
    </aside>

    <main class="hm-content" id="main-content">
        <div class="hm-topbar">
            <form class="hm-global-search" asp-controller="Search" asp-action="Index" method="get" data-global-search="true" role="search">
                <label class="visually-hidden" for="global-search-query">Global search</label>
                <div class="hm-global-search__field">
                    <span class="hm-global-search__icon" aria-hidden="true"></span>
                    <input id="global-search-query"
                           name="query"
                           value="@Context.Request.Query["query"]"
                           type="search"
                           autocomplete="off"
                           placeholder="Search pages, patients, doctors, records..."
                           aria-label="Search pages, menus and hospital data"
                           aria-controls="global-search-results"
                           aria-expanded="false" />
                    <button type="submit">Search</button>
                </div>
                <div class="hm-global-search__results" id="global-search-results" role="listbox" aria-label="Search suggestions"></div>
            </form>
        </div>
        <div class="hm-page-shell">
            @RenderBody()
        </div>
    </main>
</div>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
