@model IEnumerable<HospitalManagementApp.Models.MedicalRecord>
@{
    ViewData["Title"] = "Medical Records";
}

<div class="hm-page-header">
    <h1 class="hm-page-title">Medical Records</h1>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb hm-breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Medical Records</li>
        </ol>
    </nav>
</div>

<div class="hm-table-wrap">
    <table class="hm-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Patient</th>
                <th>Diagnosis</th>
                <th>Created</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var record in Model)
            {
                <tr>
                    <td>@record.Id</td>
                    <td>@(record.Patient != null ? $"{record.Patient.FirstName} {record.Patient.LastName}" : "—")</td>
                    <td>@record.Diagnosis</td>
                    <td>@record.CreatedAt.ToString("dd MMM yyyy")</td>
                    <td><a class="hm-btn-primary" asp-controller="MedicalRecords" asp-action="Details" asp-route-id="@record.Id">Details</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>
