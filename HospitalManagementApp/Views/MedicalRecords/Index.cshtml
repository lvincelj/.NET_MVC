@model IEnumerable<HospitalManagementApp.Models.MedicalRecord>
@{
    ViewData["Title"] = "Medical Records";
    var canManage = User.IsInRole("Admin") || User.IsInRole("Doctor");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Medical Records</h1>
    @if (canManage)
    {
        <a asp-action="Create" class="btn btn-primary">Create Medical Record</a>
    }
</div>

<div class="mb-3">
    <input
        type="search"
        class="form-control"
        placeholder="Search by patient, diagnosis, or notes..."
        data-ajax-search="true"
        data-search-url="@Url.Action("Search", "MedicalRecords")"
        data-search-target="#medical-record-list" />
</div>

<div id="medical-record-list">
    @await Html.PartialAsync("_MedicalRecordList", Model)
</div>
