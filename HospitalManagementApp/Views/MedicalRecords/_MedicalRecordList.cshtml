@model IEnumerable<HospitalManagementApp.Models.MedicalRecord>
@{
    var canManage = User.IsInRole("Admin") || User.IsInRole("Doctor");
    var canDelete = User.IsInRole("Admin");
}

@if (!Model.Any())
{
    <div class="alert alert-info hm-empty-state">No medical records found.</div>
}
else
{
    <div class="hm-cards-grid hm-cards-grid--index">
        @foreach (var item in Model)
        {
            <article class="hm-card hm-record-card hm-record-card--wide">
                <div class="hm-card__header">
                    <span class="hm-card__title">Record #@item.Id</span>
                    <span class="hm-card__badge hm-card__badge--active">@item.Prescriptions.Count Prescriptions</span>
                </div>
                <div class="hm-card__body">
                    <p><strong>Patient:</strong> @(item.Patient != null ? item.Patient.FirstName + " " + item.Patient.LastName : "-")</p>
                    <p><strong>Created:</strong> @item.CreatedAt.ToString("yyyy-MM-dd")</p>
                    <p class="hm-card__body-row hm-card__body-row--stacked"><strong>Diagnosis:</strong> <span class="hm-long-text">@item.Diagnosis</span></p>
                </div>
                <div class="hm-card__footer hm-action-strip">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">View</a>
                    @if (canManage)
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    }
                    @if (canDelete)
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    }
                </div>
            </article>
        }
    </div>
}
