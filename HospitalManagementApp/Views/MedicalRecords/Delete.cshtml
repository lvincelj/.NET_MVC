@model HospitalManagementApp.Models.MedicalRecord
@{
    ViewData["Title"] = "Delete Medical Record";
    var canDelete = ViewBag.CanDelete is bool b && b;
}

<h1>Delete Medical Record</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<dl class="row">
    <dt class="col-sm-3">Record ID</dt>
    <dd class="col-sm-9">@Model.Id</dd>
    <dt class="col-sm-3">Patient</dt>
    <dd class="col-sm-9">@(Model.Patient != null ? Model.Patient.FirstName + " " + Model.Patient.LastName : "-")</dd>
    <dt class="col-sm-3">Diagnosis</dt>
    <dd class="col-sm-9">@Model.Diagnosis</dd>
    <dt class="col-sm-3">Prescriptions</dt>
    <dd class="col-sm-9">@Model.Prescriptions.Count</dd>
</dl>

@if (!canDelete)
{
    <div class="alert alert-warning">This medical record cannot be deleted while prescriptions exist.</div>
    <a asp-controller="MedicalRecords" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Back</a>
}
else
{
    <p class="text-danger">Are you sure you want to delete this medical record?</p>
    <form asp-controller="MedicalRecords" asp-action="Delete" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-controller="MedicalRecords" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
    </form>
}
