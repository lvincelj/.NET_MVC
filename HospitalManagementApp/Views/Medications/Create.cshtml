@model HospitalManagementApp.Models.Medication
@{
    ViewData["Title"] = "Create Medication";
}

<h1>Create Medication</h1>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Dosage" class="form-label"></label>
        <input asp-for="Dosage" class="form-control" />
        <span asp-validation-for="Dosage" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PrescriptionId" class="form-label"></label>
        <div class="hm-ajax-dropdown" data-ajax-dropdown="true" data-search-url="@Url.Action("Options", "Prescriptions")">
            <input asp-for="PrescriptionId" type="hidden" />
            <input type="text" class="form-control hm-ajax-dropdown__input" value="@ViewBag.SelectedPrescriptionText" placeholder="Search prescription..." autocomplete="off" />
            <div class="hm-ajax-dropdown__menu"></div>
        </div>
        <span asp-validation-for="PrescriptionId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Instructions" class="form-label"></label>
        <textarea asp-for="Instructions" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Instructions" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
