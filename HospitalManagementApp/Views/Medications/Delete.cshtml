@model HospitalManagementApp.Models.Medication
@{
    ViewData["Title"] = "Delete Medication";
}

<h1>Delete Medication</h1>
<p class="text-danger">Are you sure you want to delete this medication?</p>

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Name</dd>
    <dt class="col-sm-3">Dosage</dt>
    <dd class="col-sm-9">@Model.Dosage</dd>
    <dt class="col-sm-3">Prescription</dt>
    <dd class="col-sm-9">#@Model.PrescriptionId</dd>
</dl>

<form asp-controller="Medications" asp-action="Delete" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-controller="Medications" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
</form>
