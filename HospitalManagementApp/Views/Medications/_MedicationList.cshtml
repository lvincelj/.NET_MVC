@model IEnumerable<HospitalManagementApp.Models.Medication>
@{
    var canManage = User.IsInRole("Admin") || User.IsInRole("Doctor");
    var canDelete = User.IsInRole("Admin");
}

@if (!Model.Any())
{
    <div class="alert alert-info hm-empty-state">No medications found.</div>
}
else
{
    <div class="hm-cards-grid hm-cards-grid--index">
        @foreach (var item in Model)
        {
            <article class="hm-card hm-record-card">
                <div class="hm-card__header">
                    <span class="hm-card__title">@item.Name</span>
                    <span class="hm-card__badge hm-card__badge--active">@item.Dosage</span>
                </div>
                <div class="hm-card__body">
                    <p><strong>Prescription:</strong> #@item.PrescriptionId</p>
                    <p class="hm-card__body-row hm-card__body-row--stacked"><strong>Instructions:</strong> <span class="hm-long-text">@(string.IsNullOrWhiteSpace(item.Instructions) ? "-" : item.Instructions)</span></p>
                </div>
                <div class="hm-card__footer hm-action-strip">
                    <a asp-controller="Medications" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary hm-action-btn hm-action-btn--view" title="View" aria-label="View medication">View</a>
                    @if (canManage)
                    {
                        <a asp-controller="Medications" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary hm-action-btn hm-action-btn--edit" title="Edit" aria-label="Edit medication">Edit</a>
                    }
                    @if (canDelete)
                    {
                        <a asp-controller="Medications" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger hm-action-btn hm-action-btn--delete" title="Delete" aria-label="Delete medication">Delete</a>
                    }
                </div>
            </article>
        }
    </div>
}
