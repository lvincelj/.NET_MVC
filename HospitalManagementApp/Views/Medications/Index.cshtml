@model IEnumerable<HospitalManagementApp.Models.Medication>
@{
    ViewData["Title"] = "Medications";
    var canManage = User.IsInRole("Admin") || User.IsInRole("Doctor");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Medications</h1>
    @if (canManage)
    {
        <a href="/Medications/Create" class="btn btn-primary">Create Medication</a>
    }
</div>

<div class="mb-3">
    <input
        type="search"
        class="form-control"
        placeholder="Search medications..."
        data-ajax-search="true"
        data-search-url="@Url.Action("Search", "Medications")"
        data-search-target="#medication-list" />
</div>

<div id="medication-list">
    @await Html.PartialAsync("_MedicationList", Model)
</div>
