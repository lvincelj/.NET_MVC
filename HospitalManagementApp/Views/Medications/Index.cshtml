@model IEnumerable<HospitalManagementApp.Models.Medication>
@{
    ViewData["Title"] = "Medications";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Medications</h1>
    <a asp-action="Create" class="btn btn-primary">Create Medication</a>
</div>

<div class="mb-3">
    <input
        type="search"
        class="form-control"
        placeholder="Search by medication name, dosage, or instructions..."
        data-ajax-search="true"
        data-search-url="@Url.Action("Search", "Medications")"
        data-search-target="#medication-list" />
</div>

<div id="medication-list">
    @await Html.PartialAsync("_MedicationList", Model)
</div>
