@model HospitalManagementApp.Services.Ai.MedicalSummaryRequest
@using HospitalManagementApp.Services.Ai
@{
    ViewData["Title"] = "AI Medical Summary";
    var result = ViewBag.SummaryResult as MedicalSummaryResult;
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1">AI Medical Summary</h1>
        <p class="hm-page-subtitle mb-0">Summarize free-text medical notes without storing the input.</p>
    </div>
</div>

<section class="hm-ai-panel">
    <form asp-action="MedicalSummary" method="post" class="hm-ai-form">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Text" class="form-label">Medical documentation text</label>
            <textarea asp-for="Text"
                      class="form-control hm-ai-textarea"
                      rows="10"
                      maxlength="6000"
                      placeholder="Paste anonymized notes, history, findings, or discharge text..."></textarea>
            <span asp-validation-for="Text" class="text-danger"></span>
        </div>

        <div class="hm-ai-actions">
            <button type="submit" class="btn btn-primary">Generate summary</button>
        </div>
    </form>

    <aside class="hm-ai-note">
        <strong>Privacy note</strong>
        <p>Remove names, identifiers, phone numbers, addresses, and other real patient data before using this feature.</p>
    </aside>
</section>

@if (result is not null)
{
    <section class="hm-ai-result" aria-live="polite">
        <h2>Summary</h2>
        <div class="hm-ai-result__body">@result.Summary</div>
        <p class="hm-ai-disclaimer">@result.Disclaimer</p>
    </section>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
