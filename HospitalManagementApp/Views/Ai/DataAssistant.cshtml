@model HospitalManagementApp.Services.Ai.DataAssistantRequest
@using HospitalManagementApp.Services.Ai
@{
    ViewData["Title"] = "Data Assistant";
    var result = ViewBag.AssistantResult as DataAssistantResult;
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1">Data Assistant</h1>
        <p class="hm-page-subtitle mb-0">Ask read-only questions across patients, appointments, doctors, departments, records, prescriptions, and medications.</p>
    </div>
</div>

<section class="hm-ai-panel">
    <form asp-action="DataAssistant" method="post" class="hm-ai-form hm-ai-chat" autocomplete="off">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="hm-chat-window" aria-live="polite">
            <div class="hm-chat-message hm-chat-message--assistant">
                <strong>Assistant</strong>
                <p>Ask a question about data already stored in CareFlow. I can also create simple read-only summaries, schedules, and patient overview documents from linked records.</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Question))
            {
                <div class="hm-chat-message hm-chat-message--user">
                    <strong>You</strong>
                    <p>@Model.Question</p>
                </div>
            }

            @if (result is not null)
            {
                <div class="hm-chat-message hm-chat-message--assistant">
                    <strong>Assistant</strong>
                    <p>@result.Answer</p>
                </div>
            }
        </div>

        <div class="hm-chat-input">
            <label asp-for="Question" class="visually-hidden">Question</label>
            <textarea asp-for="Question"
                      class="form-control"
                      rows="3"
                      maxlength="1000"
                      placeholder="Example: create a patient summary document for patient id 1"></textarea>
            <button type="submit" class="btn btn-primary">Send</button>
        </div>
        <span asp-validation-for="Question" class="text-danger"></span>
    </form>

    <aside class="hm-ai-note">
        <strong>Read-only assistant</strong>
        <p>Answers and generated documents are based on limited read-only tool results and should be verified against the official records. Bed availability is not tracked in the current data model.</p>
    </aside>
</section>

@if (result is not null)
{
    <p class="hm-ai-disclaimer">@result.Disclaimer</p>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
