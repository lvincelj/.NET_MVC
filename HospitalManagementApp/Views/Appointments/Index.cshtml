@model IEnumerable<HospitalManagementApp.Models.Appointment>
@{
    ViewData["Title"] = "Appointments";
    var canManage = User.IsInRole("Admin") || User.IsInRole("Doctor");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Appointments</h1>
    @if (canManage)
    {
        <a href="/Appointments/Create" class="btn btn-primary">Create Appointment</a>
    }
</div>

<div class="mb-3">
    <input
        type="search"
        class="form-control"
        placeholder="Search appointments..."
        data-ajax-search="true"
        data-search-url="@Url.Action("Search", "Appointments")"
        data-search-target="#appointment-list" />
</div>

<div id="appointment-list">
    @await Html.PartialAsync("_AppointmentList", Model)
</div>
