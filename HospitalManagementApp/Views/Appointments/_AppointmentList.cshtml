@model IEnumerable<HospitalManagementApp.Models.Appointment>
@{
    var canManage = User.IsInRole("Admin") || User.IsInRole("Doctor");
    var canDelete = User.IsInRole("Admin");
}

@if (!Model.Any())
{
    <div class="alert alert-info hm-empty-state">No appointments found.</div>
}
else
{
    <div class="hm-cards-grid hm-cards-grid--index">
        @foreach (var item in Model)
        {
            var statusClass = "hm-card__badge--" + item.Status.ToString().ToLowerInvariant();
            <article class="hm-card hm-record-card hm-record-card--appointment">
                <div class="hm-card__header">
                    <span class="hm-card__title">@item.ScheduledAt.ToString("yyyy-MM-dd HH:mm")</span>
                    <span class="hm-card__badge @statusClass">@item.Status</span>
                </div>
                <div class="hm-card__body">
                    <p><strong>Patient:</strong> @(item.Patient != null ? item.Patient.FirstName + " " + item.Patient.LastName : "-")</p>
                    <p><strong>Doctor:</strong> @(item.Doctor != null ? "Dr. " + item.Doctor.FirstName + " " + item.Doctor.LastName : "-")</p>
                    <p><strong>Room:</strong> @item.Room</p>
                </div>
                <div class="hm-card__footer hm-action-strip">
                    <a href="/Appointments/Details/@item.Id" class="btn btn-sm btn-outline-secondary hm-action-btn hm-action-btn--view" title="View" aria-label="View appointment">View</a>
                    @if (canManage)
                    {
                        <a href="/Appointments/Edit/@item.Id" class="btn btn-sm btn-outline-primary hm-action-btn hm-action-btn--edit" title="Edit" aria-label="Edit appointment">Edit</a>
                    }
                    @if (canDelete)
                    {
                        <a href="/Appointments/Delete/@item.Id" class="btn btn-sm btn-outline-danger hm-action-btn hm-action-btn--delete" title="Delete" aria-label="Delete appointment">Delete</a>
                    }
                </div>
            </article>
        }
    </div>
}
