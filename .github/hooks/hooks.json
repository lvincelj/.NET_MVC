{
  "hooks": {
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "powershell.exe -ExecutionPolicy Bypass -File \".github\\hooks\\log-agent-input.ps1\" -EventName UserPromptSubmit",
        "timeout": 15
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "powershell.exe -ExecutionPolicy Bypass -File \".github\\hooks\\log-agent-input.ps1\" -EventName PreToolUse",
        "timeout": 15
      }
    ]
  }
}